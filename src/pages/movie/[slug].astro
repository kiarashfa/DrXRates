---
import Base from '../../layouts/Base.astro';
import RatingPanel from '../../components/RatingPanel.svelte';
import RatingsReport from '../../components/RatingsReport.svelte';
import { movies, directors as allDirectors, directorPageFor } from '../../lib/data.js';
import { withBase, tmdbImg, fmtRuntime, fmt1 } from '../../lib/util.js';

export async function getStaticPaths() {
  return movies.map((m) => ({ params: { slug: m.slug }, props: { movie: m } }));
}

const { movie } = Astro.props;
const backdrop = tmdbImg(movie.backdrop, 'w1280');
const poster = tmdbImg(movie.poster, 'w342');
const directorLinks = movie.directors.map((d) => ({ ...d, page: directorPageFor(d.name) }));
const aslDirector = movie.asl ? allDirectors.find((d) => d.name === movie.asl.director) : null;
const reportProps = {
  id: movie.id,
  title: movie.title,
  myRating: movie.myRating,
  tmdbRating: movie.tmdbRating,
  imdbId: movie.imdbId,
  omdb: movie.omdb,
};
const panelProps = {
  id: movie.id,
  title: movie.title,
  myRating: movie.myRating,
};
---

<Base title={`${movie.title}${movie.year ? ` (${movie.year})` : ''}`} description={movie.overview ?? undefined}>
  <section class="screen-hero">
    {backdrop && <div class="backdrop" style={`background-image:url('${backdrop}')`}></div>}
    <div class="backdrop-fade"></div>
    <div class="wrap hero-inner">
      {poster && <img class="hero-poster" src={poster} alt={`${movie.title} poster`} width="200" />}
      <div>
        <h1>{movie.title}</h1>
        {movie.originalTitle && <p class="hero-meta" style="margin-top:-0.3rem;">{movie.originalTitle}</p>}
        <div class="hero-meta">
          {movie.year && <span>{movie.year}</span>}
          {movie.runtime && <span>{fmtRuntime(movie.runtime)}</span>}
          {movie.genres.length > 0 && <span>{movie.genres.join(' · ')}</span>}
        </div>
        <div class="hero-meta" style="margin-top:0.4rem;">
          {directorLinks.map((d) => (
            <span>
              directed by {d.page ? <a href={withBase(`/director/${d.page}`)} style="color:inherit;">{d.name}</a> : d.name}
            </span>
          ))}
        </div>
        {movie.tagline && <p class="tagline">“{movie.tagline}”</p>}
        <div style="margin-top:1rem; display:flex; gap:0.6rem; align-items:center; flex-wrap:wrap;">
          {movie.myRating ? (
            <span class="score-badge">{fmt1(movie.myRating.overall)} <small style="color:var(--hero-ink-muted);">/ 10</small></span>
          ) : (
            <span class="status-badge">Not yet rated</span>
          )}
        </div>
      </div>
    </div>
  </section>

  <div class="wrap" style="margin-top:2rem;">
    <RatingsReport client:only="svelte" movie={reportProps} />
  </div>

  <div class="wrap movie-cols" style="margin-top:1.5rem;" data-testid="two-col">
    <div>
      <RatingPanel client:only="svelte" movie={panelProps} />
    </div>
    <div class="panel-stack" data-testid="right-col">
      {movie.overview && (
        <div class="panel" data-testid="synopsis-panel">
          <h3>Synopsis</h3>
          <p class="muted" style="margin:0;">{movie.overview}</p>
        </div>
      )}
      {movie.cast.length > 0 && (
        <div class="panel" data-testid="cast-panel">
          <h3 class="credits-title">Cast</h3>
          {movie.cast.slice(0, 10).map((c) => (
            <div class="credit-row">
              <span class="actor">{c.name}</span>
              <span class="dots">·</span>
              <span class="role">{c.character || '—'}</span>
            </div>
          ))}
        </div>
      )}
      {movie.asl && (
        <div class="panel">
          <h3>Average shot length</h3>
          <p style="margin:0;">
            <span class="mono" style="font-size:1.5rem; color:var(--accent);">{movie.asl.value}s</span>
            <span class="muted small"> per shot</span>
          </p>
          {aslDirector && (
            <p class="small muted" style="margin:0.4rem 0 0;">
              {aslDirector.name}'s career average is {aslDirector.aslAvg}s across {aslDirector.aslCount} measured films —
              <a href={withBase(`/director/${aslDirector.slug}`)} style="color:var(--accent);">see the full picture</a>.
            </p>
          )}
        </div>
      )}
    </div>
  </div>

  {/* Designated home for my captured still frames (X archive import, pending). */}
  <section class="wrap" id="stills" data-testid="stills-home" hidden={movie.stills.length === 0} style="margin-top:2.5rem;">
    <div class="shelf-head">
      <h2>Stills</h2>
      <span class="shelf-note">frames I captured</span>
    </div>
    <div class="stills-grid">
      {movie.stills.map((s) => (
        <img src={withBase(s)} alt={`Still from ${movie.title}`} loading="lazy" />
      ))}
    </div>
  </section>
</Base>
